# ============================================================
# BeforeBook — Movie Showtime Notification App
# Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit your .env file to version control.

# ── MongoDB ──────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/beforebook
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/beforebook
MONGO_URI=mongodb://localhost:27017/beforebook

# ── Server ───────────────────────────────────────────────────
PORT=3000
# Allowed origin for CORS (your frontend URL)
CLIENT_URL=http://localhost:5173

# ── TMDB API ─────────────────────────────────────────────────
# Get your free API key at https://www.themoviedb.org/settings/api
# Used to fetch upcoming movies with region=IN&language=en-IN
TMDB_API_KEY=your_tmdb_api_key_here

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────
# For Gmail: enable 2FA, then create an App Password at:
# https://myaccount.google.com/apppasswords
# Use the generated 16-character App Password below (not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here
# The "From" name shown in notification emails
EMAIL_FROM_NAME=BeforeBook Alerts
# Where notification emails are sent (your email)
NOTIFICATION_TO_EMAIL=your_email@gmail.com

# ── WhatsApp / Twilio (Optional — stub, not active by default) ─
# Sign up at https://www.twilio.com and get these from your console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Scheduler ────────────────────────────────────────────────
# Cron expression for how often to check showtimes (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *
# Max scraper failures before marking a track as scraperError
MAX_SCRAPER_FAILURES=10
# Seconds to wait between the two showtime confirmations
SCRAPER_CONFIRM_DELAY_SECONDS=7

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=development
